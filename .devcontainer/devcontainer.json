{
  "name": "TraceArena AI World",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.12-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "22"
    }
  },
  "postCreateCommand": "python -m pip install -e \".[dev]\" && npm --prefix frontend ci",
  "forwardPorts": [5173, 8001],
  "portsAttributes": {
    "5173": {
      "label": "TraceArena frontend",
      "onAutoForward": "openBrowser"
    },
    "8001": {
      "label": "TraceArena backend",
      "onAutoForward": "notify"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "Vue.volar"
      ]
    }
  }
}
