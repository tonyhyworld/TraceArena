{
  "scenario_id": "capital_market_dual_agent_v0",
  "name": "资本市场投资模拟 v0",
  "version": "0.2.0",
  "description": "两个投资 Agent 在相同初始资金与工具权限下自主研究并交易：真实行情 + 模拟账本，限时 1 小时按组合总资产分胜负。",
  "os_version": ">=1.0.0",
  "scenario_api_version": "1.0",
  "required_os_capabilities": [
    "transactional_action_commit",
    "visibility_rules",
    "resource_lifecycle",
    "cooldown_lifecycle",
    "settlement_runtime",
    "director_plan",
    "render_commands",
    "trace_export",
    "deterministic_replay",
    "prompt_contract"
  ],
  "optional_os_capabilities": [
    "presentation_buffer"
  ],
  "author": "AI世界",
  "license": "private",
  "min_agents": 2,
  "max_agents": 2,
  "default_tick_limit": 120,
  "fairness_mode": "same_market_data_same_initial_capital",
  "enabled_features": {
    "map": false,
    "resources": true,
    "cooldown": true,
    "permissions": true,
    "visibility": true,
    "memory": true,
    "tools": true,
    "evidence": true,
    "terminal_settlement": true,
    "replay": true,
    "director": true,
    "camera_control": false
  },
  "entry_files": {
    "roles": "agents/roles.yaml",
    "prompts": "agents/prompts.yaml",
    "objects": "world/objects.yaml",
    "resources": "world/resources.yaml",
    "permissions": "world/permissions.yaml",
    "visibility": "world/visibility.yaml",
    "actions": "world/actions.yaml",
    "metrics": "world/metrics.yaml",
    "tools": "world/tools.yaml",
    "audit": "world/audit.yaml",
    "settlement": "settlement/manifest.yaml",
    "render_bindings": "render/bindings.yaml",
    "render_characters": "render/characters.yaml",
    "render_actions": "render/actions.yaml",
    "render_objects": "render/objects.yaml",
    "render_cameras": "render/cameras.yaml",
    "render_effects": "render/effects.yaml",
    "render_ui": "render/ui.yaml",
    "director": "director/director.yaml",
    "director_skills": "director/skills.yaml",
    "validation": "tests/validation.yaml",
    "sample_run": "tests/sample_run.yaml",
    "replay_expectation": "tests/replay_expectation.yaml",
    "playback_policy": "playback/playback_policy.yaml"
  }
}
