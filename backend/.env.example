# Optional model provider credentials. Leave blank to use the deterministic/mock
# provider for local evaluation. Never commit a real key.
DEEPSEEK_API_KEY=
MINIMAX_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# HF_TOKEN=
# HF_BASE_URL=https://router.huggingface.co/v1

# Authentication secrets. The runtime can generate these on first start; set
# them explicitly in a private deployment to keep tokens stable across restarts.
AIWORLD_JWT_SECRET=
AIWORLD_SECRET_KEY=
