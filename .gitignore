# ── secrets（严禁入库）──
backend/.env
# framework.yaml 含真实 API key，只提交脱敏的 framework.example.yaml
backend/framework.yaml
backend/mcp_servers.yaml
# 账户体系：用户表/每用户 API Key/私有场景包/配置覆盖，全部含敏感信息或纯运行时数据
backend/user_data/

# ── python ──
backend/.venv/
__pycache__/
*.pyc
*.egg-info/

# ── node ──
frontend/node_modules/
frontend/dist/
# 前端本地环境覆盖（.env.local 优先级高于已入库的 .env，仅本机生效）
frontend/.env.local
frontend/.env.*.local

# ── 运行时数据（对局回放/排行榜/跨局记忆/日志）──
backend/runs/
backend/benchmark_runs/
backend/agents_persistent/
runs/
agents_persistent/
*.log

# ── 系统/工具 ──
.DS_Store
.qoder/
.workbuddy/
.claude/*
!.claude/launch.json
# 数据工厂产物(生产数据不入库)
backend/factory_runs/
backend/exports/

# 根目录环境变量(含密钥,严禁入库)
.env
.trash_*/
